# ============================================================
# .env.local — copy this file and fill in your values
# Run: cp .env.example .env.local
# ============================================================

# ── Supabase (free tier — supabase.com) ──────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── OpenAI (mock locally — see scripts/mock-openai.js) ───────
# For local dev: set USE_MOCK_AI=true and leave this blank
# For demo: get a key at platform.openai.com (~$0.01 per session)
OPENAI_API_KEY=
USE_MOCK_AI=true

# ── Twilio SMS (skip locally — mock is built in) ─────────────
# For local dev: set USE_MOCK_SMS=true
# For demo: free trial gives $15 credit at twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
USE_MOCK_SMS=true

# ── Resend email (free tier: 3,000/month) ────────────────────
# Get key at resend.com — free tier is enough for demos
RESEND_API_KEY=
USE_MOCK_EMAIL=true

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# ── Cron security (any random string locally) ────────────────
CRON_SECRET=local_dev_secret_change_in_production
